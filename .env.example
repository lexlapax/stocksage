# Copy this to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./stocksage.db
# For PostgreSQL (Milestone 03+):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/stocksage

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
DEEP_THINK_LLM=gpt-5.4
QUICK_THINK_LLM=gpt-5.4-mini
OPENAI_API_KEY=sk-...

# Optional: other providers
# ANTHROPIC_API_KEY=...
# GOOGLE_API_KEY=...

# ── TradingAgents data directories ────────────────────────────────────────────
# Defaults to ~/.stocksage/{logs,cache,memory}
# STOCKSAGE_DATA_DIR=~/.stocksage

# ── Analysis defaults ─────────────────────────────────────────────────────────
# MAX_DEBATE_ROUNDS=1
# MAX_RISK_DISCUSS_ROUNDS=1
# CHECKPOINT_ENABLED=true
# OUTPUT_LANGUAGE=English

# ── Outcome resolution ────────────────────────────────────────────────────────
# How many trading days after analysis to wait before resolving outcomes
# OUTCOME_HOLDING_DAYS=5
